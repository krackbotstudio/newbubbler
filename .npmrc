# Resolve ESLint peer dependency conflict in monorepo (root eslint@4 vs @typescript-eslint/eslint-plugin@6)
legacy-peer-deps=true

# Flaky networks: Prisma @prisma/engines postinstall downloads binaries — retries help with ECONNRESET
fetch-retries=10
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
