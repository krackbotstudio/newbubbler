# Copy to apps/api/.env — use your development Supabase project only (not production).
PORT=3009
PRISMA_CLIENT_DISABLE_PREPARED_STATEMENTS=true

# From Supabase → Settings → Database → Connection string (URI).
# Pooler example (replace [YOUR-PASSWORD]; add &pgbouncer=true for Prisma + Supabase pooler):
# DATABASE_URL="postgresql://postgres.xgctfbpqavngnrtdlkss:[YOUR-PASSWORD]@....pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
DATABASE_URL=
# Optional: direct Postgres URI (db.<project>.supabase.co:5432). If `npm run prisma:migrate` hangs or fails on the pooler, temporarily point DATABASE_URL at this for migrate only, or run migrate from Supabase SQL Editor.
# After setting this, run: npm run db:ensure-role-agent  (fixes "invalid input value for enum Role: AGENT")
DATABASE_DIRECT_URL=

JWT_SECRET=dev-secret-change-in-production

# Supabase Storage (optional; default bucket name is "assets")
# Create the bucket once: npm run supabase:ensure-assets-bucket
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=assets

# Supabase Auth — JWT secret from Dashboard → Settings → API → JWT (verify tokens issued to users).
# Required for POST /auth/admin/signup/complete (real or dev OTP bypass).
# SUPABASE_JWT_SECRET=

# Local only: admin-web with NEXT_PUBLIC_DEV_SIGNUP_OTP set uses sample code 123456 (no email). Never true in production.
# ALLOW_DEV_SIGNUP_BYPASS=true

STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./storage

# Twilio Verify (optional for local dev)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
