# Supabase — use your development project (Dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_dev_anon_key

# Local API (no trailing /api — app adds /api). Match apps/api PORT (default 3009).
# Physical device: use your PC LAN IP, e.g. http://192.168.1.10:3009
EXPO_PUBLIC_API_URL=http://localhost:3009

# Twilio (optional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
