# The PWA runs apps/customer-mobile/App — use the SAME variables as apps/customer-mobile/.env
# (easiest: copy that file here as apps/customer-pwa/.env and restart `npm run dev`).

# Supabase — development project (Dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_dev_anon_key

# API origin only: no path suffix required (if you include /api it is normalized). Must match apps/api PORT.
# Example: http://localhost:3009 — not http://localhost:3009/api/something
EXPO_PUBLIC_API_URL=http://localhost:3009

# Optional: first port `npm run dev` tries when scanning for a free Metro port (default 8095).
# EXPO_CUSTOMER_PWA_PORT=8095
