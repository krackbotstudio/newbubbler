# Supabase — development project only
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_dev_anon_key

# Local API (no trailing /api). Must match apps/api PORT.
# Used at runtime and during `npm run build`: loads /api/branding/public for PWA favicon + manifest icons (appIconUrl, else logoUrl).
EXPO_PUBLIC_API_URL=http://localhost:3009
