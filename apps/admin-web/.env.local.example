# API base URL (must end with /api)
# Local (default npm run dev:api port): NEXT_PUBLIC_API_URL=http://localhost:3003/api
# If you use npm run dev:api:3009, set: http://localhost:3009/api
# Production: NEXT_PUBLIC_API_URL=https://weyouapi.krackbot.com/api
# Render:     NEXT_PUBLIC_API_URL=https://weyou-api.onrender.com/api
# Vercel (Bubbler): browser calls the API directly (CORS allows *.vercel.app on the API). Set:
# NEXT_PUBLIC_API_URL=https://bubbler-api.vercel.app/api
# Optional: only if you must avoid CORS and use the server proxy route, set NEXT_PUBLIC_USE_API_PROXY=true
# and keep API_BASE_URL for app/api-proxy (same URL as NEXT_PUBLIC_API_URL).
# API_BASE_URL=https://bubbler-api.vercel.app/api
# Vercel (generic): NEXT_PUBLIC_API_URL=https://your-api-xxx.vercel.app/api
NEXT_PUBLIC_API_URL=http://localhost:3003/api

# Customer web app URL (WhatsApp “Open our app” line). Default in code: https://bubbler-customer.vercel.app/
# NEXT_PUBLIC_CUSTOMER_APP_URL=https://bubbler-customer.vercel.app/

# Optional local dev: skip real Brevo email send — OTP step accepts sample code 123456.
# Set NEXT_PUBLIC_DEV_SIGNUP_OTP=1 and API ALLOW_DEV_SIGNUP_BYPASS=true.
# NEXT_PUBLIC_DEV_SIGNUP_OTP=1

# Optional: for Customer Simulator address search (Google Places Autocomplete)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key