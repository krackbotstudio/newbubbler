# API base URL (must end with /api)
# Local:      NEXT_PUBLIC_API_URL=http://localhost:3009/api
# Production: NEXT_PUBLIC_API_URL=https://weyouapi.krackbot.com/api
# Render:     NEXT_PUBLIC_API_URL=https://weyou-api.onrender.com/api
# Vercel:     NEXT_PUBLIC_API_URL=https://weyou-api-xxx.vercel.app/api
NEXT_PUBLIC_API_URL=http://localhost:3009/api

# Optional: Supabase (same dev project as customer apps, if needed in admin)
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key

# Optional: for Customer Simulator address search (Google Places Autocomplete)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key