# API base URL (must end with /api)
# Local (default npm run dev:api port): NEXT_PUBLIC_API_URL=http://localhost:3003/api
# If you use npm run dev:api:3009, set: http://localhost:3009/api
# Production: NEXT_PUBLIC_API_URL=https://weyouapi.krackbot.com/api
# Render:     NEXT_PUBLIC_API_URL=https://weyou-api.onrender.com/api
# Vercel:     NEXT_PUBLIC_API_URL=https://your-api-xxx.vercel.app/api
#             Admin uses /api-proxy (app/api-proxy route) to call the API from the browser. If login shows 404, set the same URL as API_BASE_URL (server) and redeploy.
# API_BASE_URL=https://your-api-xxx.vercel.app/api
NEXT_PUBLIC_API_URL=http://localhost:3003/api

# Customer web app URL (WhatsApp “Open our app” line). Default in code: https://bubbler-customer.vercel.app/
# NEXT_PUBLIC_CUSTOMER_APP_URL=https://bubbler-customer.vercel.app/

# Optional local dev: skip real Supabase email — OTP step always accepts sample code 123456. Set any truthy value (e.g. 1). Requires API ALLOW_DEV_SIGNUP_BYPASS=true and SUPABASE_JWT_SECRET.
# NEXT_PUBLIC_DEV_SIGNUP_OTP=1

# Supabase Auth for /signup (browser client). Same anon key as customer apps; URL must be HTTPS API base:
#   https://YOUR_PROJECT_REF.supabase.co
# Do not use the Postgres pooler connection string here — @supabase/supabase-js needs the REST/auth URL.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
#
# /signup expects a numeric email OTP (Supabase often sends 6 or 8 digits). In Authentication → Email templates, BOTH must use
# {{ .Token }} and NOT {{ .ConfirmationURL }}: (1) Magic link — (2) Confirm signup. Samples in apps/admin-web/supabase/

# Optional: for Customer Simulator address search (Google Places Autocomplete)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key