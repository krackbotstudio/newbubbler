PORT=3009
# --- Dev Supabase (use your development project only; never commit real passwords) ---
# Dashboard → Project Settings → Database → URI. Add ?sslmode=require for Prisma.
# DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
# Optional: direct URL for migrations (same DB or Supabase "direct" connection)
# DATABASE_DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL=
DATABASE_DIRECT_URL=
PORT=3005
# Local Postgres example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/laundry_app"
# Supabase (replace <PASSWORD> and <PROJECT_REF> with real values; no angle brackets at runtime):
# DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"
# If password has special chars, URL-encode: @ -> %40, # -> %23, / -> %2F, etc.
//DATABASE_URL="postgresql://postgres:postgres@localhost:5432/laundry_app"
DATABASE_URL="postgresql://postgres.63f4945d921d599f27ae4fdf5bada3f3:etisxghsmjkjn8c01gd3y42lituunf8m@187.127.128.214:5432/postgres?sslmode=disable&pgbouncer=true&statement_cache_size=0"
JWT_SECRET="dev-secret"
# Local storage (default)
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./storage

# Supabase Storage (uncomment to use cloud storage)
# SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
# SUPABASE_STORAGE_BUCKET="assets"
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=laundry-invoices
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret

JWT_SECRET="dev-secret-change-in-production"
LOCAL_STORAGE_ROOT="./storage"
PRISMA_CLIENT_DISABLE_PREPARED_STATEMENTS=true

# Twilio (optional for local dev OTP; without it OTP 123456 may work)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# Optional: S3 / MinIO for file storage
# STORAGE_DRIVER=local
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=laundry-invoices
# S3_ACCESS_KEY=minio
# S3_SECRET_KEY=miniosecret

# Customer apps (Expo) — copy to apps/customer-pwa/.env and apps/customer-mobile/.env
# Use Supabase Dashboard → Project Settings → API (Project URL + anon public key)
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR_DEV_PROJECT_REF.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_dev_anon_key
# EXPO_PUBLIC_API_URL=http://localhost:3009
